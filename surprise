
<html>
<head>
<title>Happy Birthday Ma'am ❤️</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI',sans-serif;
}

body{
  overflow:hidden;
  background:#ffc0cb;
  color:black;
}

/* Slide System */
.page{
  height:100vh;
  width:100%;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  padding:40px;
  position:absolute;
  top:0;
  left:100%;
  opacity:0;
  transition:all 0.6s ease;
}

.active{
  left:0;
  opacity:1;
}

.exit{
  left:-100%;
  opacity:0;
}

h1{
  font-size:40px;
  margin-bottom:20px;
}

p{
  font-size:20px;
  max-width:800px;
  line-height:1.6;
  margin-bottom:20px;
}

.page img{
  width:70%;
  height:60vh;
  object-fit:cover;
  border-radius:20px;
  box-shadow:0 15px 40px gray;
  margin-bottom:20px;
}

/* Vertical collage */
.collage-vertical{
  width:320px !important;
  height:570px !important;
  object-fit:cover !important;
}

/* Vertical Video */
.video-container{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:20px;
}

video{
  width:320px;
  height:570px;
  object-fit:cover;
  border-radius:20px;
  box-shadow:0 15px 40px rgba(0,0,0,0.3);
}

/* Navigation */
.nav{
  position:fixed;
  bottom:25px;
  width:100%;
  display:flex;
  justify-content:center;
}

button{
  padding:12px 25px;
  font-size:16px;
  border:none;
  border-radius:30px;
  background:#ff69b4;
  color:white;
  cursor:pointer;
  transition:0.3s;
}

button:hover{
  background:#ff4fa3;
  transform:scale(1.05);
}

/* Floating Emojis */
.floating{
  position:fixed;
  bottom:-20px;
  font-size:22px;
  animation:floatUp 6s linear infinite;
  z-index:0;
  opacity:0.8;
  pointer-events:none;
}

@keyframes floatUp{
  from{
    transform:translateY(0) scale(1);
    opacity:1;
  }
  to{
    transform:translateY(-110vh) scale(1.6);
    opacity:0;
  }
}

footer{
  margin-top:20px;
  font-size:18px;
  font-weight:bold;
}
</style>
</head>

<body>

<audio id="bgMusic" loop>
  <source src="bgm.mpeg" type="audio/mpeg">
</audio>

